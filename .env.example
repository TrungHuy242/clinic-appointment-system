# Clinic Appointment System - Production Environment Variables
# Copy this file to .env and fill in the values

# ── Django ──────────────────────────────────────────────────────────────────────
DJANGO_DEBUG=false
DJANGO_SECRET_KEY=your-super-secret-key-change-this
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,clinic-app.example.com

# ── Database ─────────────────────────────────────────────────────────────────────
DB_ENGINE=postgresql
DB_HOST=localhost
DB_PORT=5432
DB_NAME=clinic_appointment_system
DB_USER=postgres
DB_PASSWORD=your-db-password

# ── JWT ─────────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-key-change-this
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ── Demo Data (set to true to seed on first start) ──────────────────────────────
SEED_DEMO_DATA=false
